generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  name      String
  email     String   @unique
  role      String   @default("Rep")
  avatar    String   @default("")
  color     String   @default("#6366f1")
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Client {
  id        String    @id
  name      String
  domain    String    @default("")
  color     String    @default("#6366f1")
  industry  String    @default("")
  plan      String    @default("Starter")
  mrr       Int       @default(0)
  createdAt      DateTime       @default(now()) @map("created_at")
  contacts       Contact[]
  contactGroups  ContactGroup[]
  emailTemplates EmailTemplate[]

  @@map("clients")
}

model ContactGroup {
  id        String   @id @default(uuid())
  clientId  String?  @map("client_id")

  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contacts  Contact[]

  @@unique([clientId, name])
  @@index([clientId])
  @@map("contact_groups")
}

model Contact {
  id             String     @id @default(uuid())
  pool           String     @default("prospect")
  clientId       String?    @map("client_id")
  firstName      String     @map("first_name")
  lastName       String     @default("") @map("last_name")
  email          String     @default("")
  phone          String     @default("")
  company        String     @default("")
  title          String     @default("")
  website        String     @default("")
  city           String     @default("")
  trucks         Int        @default(0) // 
  lifecycleStage String     @default("new") @map("lifecycle_stage")
  leadScore      Int        @default(0) @map("lead_score")
  status         String     @default("active")
  source         String     @default("")
  campaign       String     @default("")
  emailsSent     Int        @default(0) @map("emails_sent")
  emailsOpened   Int        @default(0) @map("emails_opened")
  emailsClicked  Int        @default(0) @map("emails_clicked")
  callsMade      Int        @default(0) @map("calls_made")
  callsAnswered  Int        @default(0) @map("calls_answered")
  lastActivityAt DateTime   @default(now()) @map("last_activity_at")
  contractValue  Int        @default(0) @map("contract_value")
  accountSize    String     @default("1-5") @map("account_size")
  tags           String @default("[]")
  notes          String     @default("")
  ownedBy        String     @default("") @map("owned_by")
  addedBy        String     @default("") @map("added_by")
  createdAt      DateTime   @default(now()) @map("created_at")
  client         Client?    @relation(fields: [clientId], references: [id])
  activities     Activity[]

  contactGroupId String? @map("contact_group_id")
  contactGroup   ContactGroup? @relation(fields: [contactGroupId], references: [id], onDelete: SetNull)

  @@map("contacts")
}

model Activity {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  type      String
  note      String   @default("")
  by        String   @default("")
  ts        DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Domain {
  id                String   @id @default(uuid())
  clientId          String?  @map("client_id")
  domainName        String   @unique @map("domain_name")
  resendDomainId    String   @map("resend_domain_id")
  status            String   @default("pending")
  defaultFromEmail  String   @default("") @map("default_from_email")
  spfRecord         String   @default("") @map("spf_record")
  dkimRecord        String   @default("") @map("dkim_record")
  dmarcRecord       String   @default("") @map("dmarc_record")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("domains")
}

model EmailTemplate {
  id           String   @id @default(uuid())
  clientId     String?  @map("client_id")

  name         String
  subject      String   @default("")
  body         String     @default("{\"blocks\": [], \"version\": 1}")
  htmlOutput   String   @default("") @map("html_output")
  trackedLinks String @default("[]") @map("tracked_links")
  status       String   @default("draft")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@map("email_templates")
}

model InteractiveSession {
  id          String    @id @default(uuid())
  contactId   String?   @map("contact_id")
  templateId  String?   @map("template_id")
  blockId     String    @map("block_id")
  type        String
  config      String @default("{}")
  token       String    @unique @default(uuid())
  response    String?
  respondedAt DateTime? @map("responded_at")
  scoreGiven  Int       @default(0) @map("score_given")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([contactId])
  @@index([templateId])
  @@map("interactive_sessions")
}