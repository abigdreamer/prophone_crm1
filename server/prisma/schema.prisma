generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Company (one per tenant) ───────────────────────────────────────────────────
model company_profile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id String   @unique                      // e.g. "foxtow", "acme-towing"
  name        String
  website     String   @default("")
  city        String   @default("")
  address     String   @default("")
  zipcode     String   @default("")
  state       String   @default("")
  country     String   @default("")
  phone       String   @default("")
  email       String   @default("")
  fax         String   @default("")
  industry    String   @default("")
  timezone    String   @default("")
  plan        String   @default("starter")
  notes       String   @default("")
  metadata    Json     @default("{}")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users          user[]
  contacts       contact[]
  contact_groups contact_group[]

  @@map("company_profiles")
}

// ── Users ──────────────────────────────────────────────────────────────────────
model user {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id String?                               // null for super_admin; required for admin/rep
  email       String   @unique
  password    String
  name        String   @default("")
  role        String   @default("rep")              // rep | admin | super_admin
  avatar      String   @default("")
  color       String   @default("")
  created_at  DateTime @default(now())

  company company_profile? @relation(fields: [prophone_id], references: [prophone_id])

  @@index([prophone_id])
  @@map("users")
}

// ── Contacts ───────────────────────────────────────────────────────────────────
model contact {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id     String
  first_name      String    @default("")
  last_name       String    @default("")
  email           String?
  phone           String    @default("")
  company         String    @default("")
  title           String    @default("")
  website         String    @default("")
  city            String    @default("")
  lifecycle_stage String    @default("new")
  status          String    @default("active")
  source          String    @default("")
  tags            String[]  @default([])
  notes           String    @default("")
  owned_by        String    @default("")
  added_by        String    @default("")
  group_id        String?   @db.Uuid
  last_activity_at DateTime @default(now())
  created_at      DateTime  @default(now())

  company_rel company_profile @relation(fields: [prophone_id], references: [prophone_id])
  activities  activity[]
  group       contact_group?  @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([prophone_id])
  @@index([group_id])
  @@map("contacts")
}

// ── Contact Groups ─────────────────────────────────────────────────────────────
model contact_group {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id String
  name        String
  created_by  String   @default("")
  created_at  DateTime @default(now())

  company_rel company_profile @relation(fields: [prophone_id], references: [prophone_id])
  contacts    contact[]

  @@unique([prophone_id, name])
  @@index([prophone_id])
  @@map("contact_groups")
}

// ── Activities ─────────────────────────────────────────────────────────────────
model activity {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contact_id String   @db.Uuid
  type       String
  note       String   @default("")
  by         String   @default("")
  ts         DateTime @default(now())

  contact contact @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@map("activities")
}

// ── Email Templates ────────────────────────────────────────────────────────────
model email_template {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id    String
  name           String
  subject        String   @default("")
  json_structure Json     @default("{\"version\":1,\"blocks\":[]}")
  html_output    String   @default("")
  status         String   @default("draft")
  version        Int      @default(1)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  campaigns campaign[]

  @@index([prophone_id, updated_at(sort: Desc)])
  @@map("email_templates")
}

// ── Sending Domains ────────────────────────────────────────────────────────────
model domain {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id      String
  domain           String
  resend_domain_id String?
  status           String    @default("pending")  // pending | verifying | verified | failed
  dns_records      Json?
  region           String    @default("us-east-1")
  from_email       String    @default("")
  verified_at      DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@unique([prophone_id, domain])
  @@index([prophone_id])
  @@map("domains")
}

// ── Campaigns ──────────────────────────────────────────────────────────────────
model campaign {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prophone_id   String
  name          String
  subject       String   @default("")
  from_name     String   @default("")
  from_email    String   @default("")
  template_id   String?  @db.Uuid
  status        String   @default("draft")   // draft | running | paused | completed | failed
  scheduled_at  DateTime?
  sent_count       Int      @default(0)
  opened_count     Int      @default(0)
  clicked_count    Int      @default(0)
  bounced_count    Int      @default(0)
  failed_count     Int      @default(0)
  html_snapshot    String   @default("")
  ab_subject_b     String   @default("")
  ab_template_id_b String?  @db.Uuid
  ab_html_snapshot String   @default("")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  template   email_template?    @relation(fields: [template_id], references: [id], onDelete: SetNull)
  recipients campaign_recipient[]

  @@index([prophone_id, status])
  @@map("campaigns")
}

// ── Campaign Recipients ────────────────────────────────────────────────────────
model campaign_recipient {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id   String    @db.Uuid
  contact_id    String?   @db.Uuid
  email         String
  first_name    String    @default("")
  last_name     String    @default("")
  phone         String    @default("")
  company       String    @default("")
  city          String    @default("")
  title         String    @default("")
  ab_variant    String    @default("A")
  status        String    @default("pending")
  message_id    String    @default("")
  sent_at       DateTime?
  delivered_at  DateTime?
  opened_at     DateTime?
  clicked_at    DateTime?
  bounced_at    DateTime?
  error_message String    @default("")
  attempts      Int       @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  campaign campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, email])
  @@index([campaign_id, status])
  @@index([message_id])
  @@map("campaign_recipients")
}
