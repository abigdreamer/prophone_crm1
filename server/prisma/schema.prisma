generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id
  name      String
  email     String   @unique
  role      String   @default("Rep")
  avatar    String   @default("")
  color     String   @default("#6366f1")
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("users")
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id           String    @id
  name         String
  domain       String    @default("")
  color        String    @default("#6366f1")
  industry     String    @default("")
  plan         String    @default("Starter")
  mrr          Int       @default(0)
  isCanceled   Boolean   @default(false) @map("is_canceled")
  canceledAt   DateTime? @map("canceled_at")
  canceledBy   String    @default("") @map("canceled_by")
  cancelReason String    @default("") @map("cancel_reason")
  restoredAt   DateTime? @map("restored_at")
  restoredBy   String    @default("") @map("restored_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt     @map("updated_at")

  contacts       Contact[]
  contactGroups  ContactGroup[]
  emailTemplates EmailTemplate[]
  campaigns      Campaign[]
  templateLinks  TemplateLink[]
  redditMonitors RedditMonitor[]
  redditPosts    RedditPost[]
  portalUsers    ClientUser[]
  userDefinedFields   UserDefinedField[]
  customSortOptions   CustomSortOption[]
  customFilterOptions CustomFilterOption[]

  @@map("clients")
}

// ─── Client Portal Users ──────────────────────────────────────────────────────

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  name      String
  email     String?
  username  String   @unique
  password  String
  role      String   @default("viewer")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_users")
}

// ─── Contacts ─────────────────────────────────────────────────────────────────

model ContactGroup {
  id        String   @id @default(uuid())
  clientId  String?  @map("client_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contacts Contact[]

  @@unique([clientId, name])
  @@index([clientId])
  @@map("contact_groups")
}

model Contact {
  id             String    @id @default(uuid())
  pool           String    @default("prospect")
  clientId       String?   @map("client_id")
  contactGroupId String?   @map("contact_group_id")
  firstName      String    @map("first_name")
  lastName       String    @default("") @map("last_name")
  email          String    @default("")
  phone          String    @default("")
  company        String    @default("")
  title          String    @default("")
  website        String    @default("")
  address               String    @default("")
  city                  String    @default("")
  state                 String    @default("")
  zip                   String    @default("")
  trucks                Int       @default(0)
  servicesOffered       String    @default("") @map("services_offered")
  motorClubAffiliations String    @default("") @map("motor_club_affiliations")
  dispatcherSoftware    String    @default("") @map("dispatcher_software")
  painPoints            String    @default("") @map("pain_points")
  estAnnualRevenue      String    @default("") @map("est_annual_revenue")
  serviceAreaMiles      Int       @default(0)  @map("service_area_miles")
  yearsInBusiness       Int       @default(0)  @map("years_in_business")
  lifecycleStage        String    @default("new") @map("lifecycle_stage")
  leadScore             Int       @default(0) @map("lead_score")
  status         String    @default("active")
  source         String    @default("")
  campaign       String    @default("")
  emailsSent     Int       @default(0) @map("emails_sent")
  emailsOpened   Int       @default(0) @map("emails_opened")
  emailsClicked  Int       @default(0) @map("emails_clicked")
  callsMade      Int       @default(0) @map("calls_made")
  callsAnswered  Int       @default(0) @map("calls_answered")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  contractValue  Int       @default(0) @map("contract_value")
  accountSize    String    @default("1-5") @map("account_size")
  tags           String[]  @default([])
  description    String    @default("")
  socialLinks    Json      @default("{}") @map("social_links")
  udfValues      Json      @default("{}") @map("udf_values")
  notes          String    @default("")
  ownedBy        String    @default("") @map("owned_by")
  addedBy        String    @default("") @map("added_by")
  isCanceled     Boolean   @default(false) @map("is_canceled")
  canceledAt     DateTime? @map("canceled_at")
  canceledBy     String    @default("") @map("canceled_by")
  cancelReason   String    @default("") @map("cancel_reason")
  restoredAt     DateTime? @map("restored_at")
  restoredBy     String    @default("") @map("restored_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt     @map("updated_at")

  client             Client?            @relation(fields: [clientId], references: [id])
  contactGroup       ContactGroup?      @relation(fields: [contactGroupId], references: [id], onDelete: SetNull)
  campaignRecipients CampaignRecipient[]

  @@map("contacts")
}

// ─── User Defined Fields ──────────────────────────────────────────────────────

model UserDefinedField {
  id           String   @id @default(uuid())
  clientId     String?  @map("client_id")
  label        String
  type         String   @default("TEXT")
  options      Json     @default("[]")
  sortKey      String   @unique          @map("sort_key")
  isActive     Boolean  @default(true)   @map("is_active")
  displayOrder Int      @default(0)      @map("display_order")
  createdAt    DateTime @default(now())  @map("created_at")
  updatedAt    DateTime @updatedAt       @map("updated_at")

  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId])
  @@map("user_defined_fields")
}

// ─── Custom Sort / Filter Options ────────────────────────────────────────────

model CustomSortOption {
  id           String   @id @default(uuid())
  clientId     String?  @map("client_id")
  label        String
  sortValue    String   @default("") @map("sort_value")
  contactField String   @default("") @map("contact_field")
  direction    String   @default("asc")
  isBuiltIn    Boolean  @default(false) @map("is_built_in")
  isActive     Boolean  @default(true)  @map("is_active")
  displayOrder Int      @default(0)     @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId])
  @@map("custom_sort_options")
}

model CustomFilterOption {
  id           String   @id @default(uuid())
  clientId     String?  @map("client_id")
  label        String
  contactField String   @map("contact_field")
  filterType   String   @default("TEXT") @map("filter_type")
  options      Json     @default("[]")
  isBuiltIn    Boolean  @default(false) @map("is_built_in")
  isActive     Boolean  @default(true)  @map("is_active")
  displayOrder Int      @default(0)     @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId])
  @@map("custom_filter_options")
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model Activity {
  id         String   @id @default(uuid())
  entityType String   @default("contact") @map("entity_type")
  entityId   String   @default("") @map("entity_id")
  type       String
  note       String   @default("")
  by         String   @default("")
  points     Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt     @map("updated_at")

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("activities")
}

// ─── Domains ──────────────────────────────────────────────────────────────────

model Domain {
  id               String    @id @default(uuid())
  clientId         String?   @map("client_id")
  domainName       String    @unique @map("domain_name")
  resendDomainId   String    @map("resend_domain_id")
  status           String    @default("pending")
  defaultFromEmail String    @default("") @map("default_from_email")
  spfRecord        String    @default("") @map("spf_record")
  dkimRecord       String    @default("") @map("dkim_record")
  dmarcRecord      String    @default("") @map("dmarc_record")
  isCanceled       Boolean   @default(false) @map("is_canceled")
  canceledAt       DateTime? @map("canceled_at")
  cancelReason     String    @default("") @map("cancel_reason")
  restoredAt       DateTime? @map("restored_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt     @map("updated_at")

  @@map("domains")
}

// ─── Email Templates & Links ──────────────────────────────────────────────────

model EmailTemplate {
  id           String    @id @default(uuid())
  clientId     String?   @map("client_id")
  name         String
  subject      String    @default("")
  fromEmail    String    @default("") @map("from_email")
  body         Json      @default("{\"blocks\": [], \"version\": 1}")
  htmlOutput   String    @default("") @map("html_output")
  trackedLinks Json      @default("[]") @map("tracked_links")
  status       String    @default("draft")
  isCanceled   Boolean   @default(false) @map("is_canceled")
  canceledAt   DateTime? @map("canceled_at")
  cancelReason String    @default("") @map("cancel_reason")
  restoredAt   DateTime? @map("restored_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt     @map("updated_at")

  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  campaigns Campaign[]
  links     TemplateLink[]

  @@index([clientId])
  @@map("email_templates")
}

model ScoringRule {
  id          String    @id @default(uuid())
  name        String
  description String    @default("")
  points      Int
  event       String    @default("link_click")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt     @map("updated_at")

  links TemplateLink[]

  @@index([isActive])
  @@map("scoring_rules")
}

model TemplateLink {
  id            String    @id @default(uuid())
  templateId    String    @map("template_id")
  clientId      String?   @map("client_id")
  url           String
  label         String    @default("")
  scoringRuleId String?   @map("scoring_rule_id")
  clickCount    Int       @default(0) @map("click_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt     @map("updated_at")

  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  scoringRule ScoringRule?  @relation(fields: [scoringRuleId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([clientId])
  @@map("template_links")
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id                String    @id @default(uuid())
  clientId          String?   @map("client_id")
  name              String
  type              String    @default("regular")
  status            String    @default("draft")
  templateId        String?   @map("template_id")
  templateIdB       String?   @map("template_id_b")
  subject           String    @default("")
  subjectB          String    @default("") @map("subject_b")
  fromName          String    @default("") @map("from_name")
  fromEmail         String    @default("") @map("from_email")
  sentAt            DateTime? @map("sent_at")
  completedAt       DateTime? @map("completed_at")
  recipientsCount   Int       @default(0) @map("recipients_count")
  sentCount         Int       @default(0) @map("sent_count")
  deliveredCount    Int       @default(0) @map("delivered_count")
  openedCount       Int       @default(0) @map("opened_count")
  clickedCount      Int       @default(0) @map("clicked_count")
  bouncedCount      Int       @default(0) @map("bounced_count")
  unsubscribedCount Int       @default(0) @map("unsubscribed_count")
  isCanceled        Boolean   @default(false) @map("is_canceled")
  canceledAt        DateTime? @map("canceled_at")
  cancelReason      String    @default("") @map("cancel_reason")
  restoredAt        DateTime? @map("restored_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt     @map("updated_at")

  client     Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients CampaignRecipient[]

  @@index([clientId])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String    @id @default(uuid())
  campaignId String    @map("campaign_id")
  contactId  String    @map("contact_id")
  abVariant  String?   @map("ab_variant")
  status         String    @default("pending")
  skipReason     String?   @map("skip_reason")
  resubscribedAt DateTime? @map("resubscribed_at")
  messageId  String?   @map("message_id")
  sendId     String?   @map("send_id")
  sendLabel  String    @default("") @map("send_label")
  sentAt     DateTime? @map("sent_at")
  openedAt   DateTime? @map("opened_at")
  clickedAt  DateTime? @map("clicked_at")
  bouncedAt  DateTime? @map("bounced_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt     @map("updated_at")

  campaign Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events   CampaignRecipientEvent[]

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([sendId])
  @@map("campaign_recipients")
}

model CampaignRecipientEvent {
  id          String   @id @default(uuid())
  recipientId String   @map("recipient_id")
  campaignId  String   @map("campaign_id")
  sendId      String?  @map("send_id")
  event       String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  recipient CampaignRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([campaignId])
  @@index([sendId])
  @@map("campaign_recipient_events")
}

// ─── Interactive Sessions ─────────────────────────────────────────────────────

model InteractiveSession {
  id          String    @id @default(uuid())
  contactId   String?   @map("contact_id")
  templateId  String?   @map("template_id")
  blockId     String    @map("block_id")
  type        String
  config      Json      @default("{}")
  token       String    @unique @default(uuid())
  response    Json?
  respondedAt DateTime? @map("responded_at")
  scoreGiven  Int       @default(0) @map("score_given")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt     @map("updated_at")

  @@index([contactId])
  @@index([templateId])
  @@map("interactive_sessions")
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model ContactFieldSettings {
  id        String   @id @default(uuid())
  clientId  String?  @map("client_id")
  module    String
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@unique([clientId, module])
  @@index([clientId])
  @@map("contact_field_settings")
}

// ─── Reddit Monitoring ───────────────────────────────────────────────────────

model RedditMonitor {
  id              String   @id @default(uuid())
  clientId        String   @map("client_id")
  subreddit       String
  keywords        String[]
  isActive        Boolean  @default(true) @map("is_active")
  pollIntervalSec Int      @default(60)   @map("poll_interval_sec")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt     @map("updated_at")

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  posts  RedditPost[]

  @@index([clientId])
  @@map("reddit_monitors")
}

model RedditPost {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  monitorId       String    @map("monitor_id")
  redditId        String    @unique @map("reddit_id")
  subreddit       String
  title           String
  body            String    @default("")
  author          String
  permalink       String
  redditCreatedAt DateTime  @map("reddit_created_at")
  matchedKeywords String[]  @map("matched_keywords")
  status          String    @default("new")
  aiDraft         String?   @map("ai_draft")
  postedComment   String?   @map("posted_comment")
  discoveredAt    DateTime  @default(now()) @map("discovered_at")
  draftedAt       DateTime? @map("drafted_at")
  postedAt        DateTime? @map("posted_at")
  dismissedAt     DateTime? @map("dismissed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt     @map("updated_at")

  client  Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  monitor RedditMonitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  events  RedditPostEvent[]

  @@index([clientId])
  @@index([monitorId])
  @@index([status])
  @@map("reddit_posts")
}

model RedditPostEvent {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  post RedditPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("reddit_post_events")
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model PosthogProject {
  id         String   @id @default(uuid())
  key        String   @unique
  label      String
  domain     String
  project_id String
  sort_order Int      @default(0)
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt     @map("updated_at")

  @@map("posthog_projects")
}
